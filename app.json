{
  "expo": {
    "name": "List Kitty",
    "slug": "list",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "list",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "icon": {
        "light": "./assets/images/icon.png",
        "dark": "./assets/images/icon-dark.png"
      }
    },
    "android": {
      "icon": "./assets/images/icon.png",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#EDE4D4",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.goode_company.listkitty"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "splash": {
        "backgroundColor": "#DBB793"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#DBB793",
          "ios": {
            "backgroundColor": "#DBB793"
          },
          "android": {
            "backgroundColor": "#DBB793",
            "drawable": {
              "icon": "./assets/images/android-splash-icon.xml"
            }
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cd6aa440-0d80-41c4-b6c9-c8d303c0b47e"
      }
    }
  }
}

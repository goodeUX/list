{
  "expo": {
    "name": "List App",
    "slug": "list",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "list",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "icon": "./assets/images/icon.png",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#EDE4D4",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.geo_goo.list"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "splash": {
        "backgroundColor": "#DBB793",
        "image": "./assets/images/splash-background.png",
        "resizeMode": "cover"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#DBB793",
          "ios": {
            "backgroundColor": "#DBB793",
            "image": "./assets/images/splash-background.png",
            "resizeMode": "cover",
            "enableFullScreenImage_legacy": true
          },
          "android": {
            "backgroundColor": "#DBB793"
          }
        }
      ],
      "./plugins/withAndroidSplashNoIcon.js",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cd6aa440-0d80-41c4-b6c9-c8d303c0b47e"
      }
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function memberIds(data) {
      return data.get('memberIds', []);
    }

    function isListMember(listId) {
      return isSignedIn()
        && request.auth.uid in memberIds(
          get(/databases/$(database)/documents/lists/$(listId)).data
        );
    }

    function isJoiningList() {
      return !(request.auth.uid in memberIds(resource.data))
        && request.auth.uid in memberIds(request.resource.data)
        && memberIds(request.resource.data).size()
           == memberIds(resource.data).size() + 1
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['memberIds', 'updatedAt']);
    }

    function isLeavingList() {
      return request.auth.uid in memberIds(resource.data)
        && !(request.auth.uid in memberIds(request.resource.data))
        && resource.data.ownerId != request.auth.uid
        && memberIds(request.resource.data).size()
           == memberIds(resource.data).size() - 1
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['memberIds', 'updatedAt']);
    }

    match /users/{uid} {
      // Collaborators need to see each other's display name / email on shared lists.
      allow get: if isSignedIn();
      allow write: if isOwner(uid);

      match /itemHistory/{historyId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /lists/{listId} {
      // Invite flow: signed-in users can read a list before they are members.
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && request.auth.uid in memberIds(resource.data);

      allow create: if isSignedIn()
        && request.auth.uid in memberIds(request.resource.data)
        && request.resource.data.ownerId == request.auth.uid;

      allow update: if isSignedIn()
        && (
          (
            request.auth.uid in memberIds(resource.data)
            && request.auth.uid in memberIds(request.resource.data)
          )
          || isJoiningList()
          || isLeavingList()
        );

      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.ownerId;

      match /items/{itemId} {
        allow read, write: if isListMember(listId);
      }

      match /presence/{uid} {
        allow read: if isListMember(listId);
        allow write: if isListMember(listId) && request.auth.uid == uid;
      }
    }
  }
}

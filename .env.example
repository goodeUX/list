# Copy to `.env` and fill in values from Firebase Console → Project settings → Your apps → Web app config.
# Restart the Expo dev server after changing env vars.
# Firebase Storage is not used — no storage bucket needed.

EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id

# Public web URL for invite links (must be https). Defaults to https://<FIREBASE_PROJECT_ID>.web.app
# EXPO_PUBLIC_APP_WEB_URL=https://your-project.web.app

# App Store URL shown on mobile invite landing pages (required for iOS store redirect)
# EXPO_PUBLIC_IOS_APP_STORE_URL=https://apps.apple.com/app/idYOUR_APP_ID
# EXPO_PUBLIC_IOS_APP_STORE_ID=YOUR_APP_ID

# Universal links — generate with: node scripts/generate-well-known.js
# EXPO_PUBLIC_IOS_TEAM_ID=YOUR_APPLE_TEAM_ID
# EXPO_PUBLIC_IOS_BUNDLE_ID=com.geo_goo.list
# EXPO_PUBLIC_ANDROID_PACKAGE=com.geo_goo.list
# EXPO_PUBLIC_ANDROID_SHA256_CERT=AA:BB:CC:...
